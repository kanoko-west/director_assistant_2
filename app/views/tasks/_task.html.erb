<%= turbo_frame_tag dom_id(task) do %>
  <div class="task-card" id="<%= dom_id(task) %>">
    <div class="task-content">
      <div class="task-check-wrapper">
        <%# 送信先を update_status_task_path に変更し、status: "done" を渡します %>
        <%= form_with(url: update_status_task_path(id: task.id, status: "done"), method: :patch) do |f| %>
          <%= f.check_box :status, 
              { class: "task-checkbox", onchange: "this.form.requestSubmit()" }, 
              "done", 
              "todo" %>
        <% end %>
      </div>

      <div class="task-info">
        <h3 class="task-title"><%= task.title %></h3>
        <p class="task-deadline"><%= task.due_date %></p>
      </div>
    </div>

    <div class="task-actions">
      <%= link_to "編集", edit_task_path(task), class: "edit-link" %>
    </div>
  </div>
<% end %>