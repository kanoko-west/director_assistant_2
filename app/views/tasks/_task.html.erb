<%= turbo_frame_tag dom_id(task) do %>
  <div class="task-card">
    <div class="task-content">
      <div class="task-check-wrapper">
        <%# 送信先を archive_task_path に指定し、method を patch にします %>
        <%= form_with(model: task, url: archive_task_path(task), method: :patch) do |f| %>
          <%= f.check_box :archived, onchange: "this.form.requestSubmit()", class: "task-checkbox" %>
        <% end %>
      </div>

      <div class="task-info">
        <h3 class="task-title"><%= task.title %></h3>
        <p class="task-deadline"><%= task.due_date %></p>
      </div>
    </div>

    <div class="task-actions">
      <%= link_to "編集", edit_task_path(task), class: "edit-link" %>
    </div>
  </div>
<% end %>