<div class="routine-container">
  <header class="routine-header">
    <h1>🔄 日常業務マスター登録</h1>
  </header>

  <%# 登録フォームエリア %>
  <section class="routine-form-section">
    <h2 class="section-title">新しい日常業務を追加</h2>
    <%= form_with(model: @task, class: "routine-quick-form") do |f| %>
      <%= f.hidden_field :is_routine, value: 1 %>
      
      <div class="input-group">
        <%= f.text_field :title, 
            placeholder: "例：数値チェック、定例準備など", 
            class: "input-text-master",
            autocomplete: "off" %>
        <%= f.submit "マスター登録", class: "btn-primary-master" %>
      </div>
    <% end %>
  </section>

  <%# マスター一覧テーブル %>
  <section class="routine-list-section">
    <div class="table-scroll-wrapper">
      <table class="routine-table">
        <thead>
          <tr>
            <th class="col-title">業務名</th>
            <th class="col-action">操作</th>
          </tr>
        </thead>
        <tbody id="master_routine_list">
          <% @routine_tasks.each do |task| %>
            <tr id="<%= dom_id(task) %>">
              <td class="task-title"><%= task.title %></td>
              <td class="task-action">
                <%= link_to "削除", task_path(task), 
                    data: { turbo_method: :delete, turbo_confirm: "この日常業務を削除しますか？" }, 
                    class: "btn-delete-text" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
