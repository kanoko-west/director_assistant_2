<main class="app-main-content">
        <!-- 1. 爆速タスク登録 -->
<section class="section-quick-input">
  <h2 class="font-bold mb-4 flex items-center gap-2">⚡ 爆速タスク登録</h2>
  
  <div id="new_task_form_container">
    <%= render "form_quick_input", task: @task, from_view: "index" %>
  </div>
</section>

        <!-- 2. タスク一覧 -->
        <section class="mb-10">
        <div class="flex justify-between items-end mb-4">
            <h2 class="text-xl font-bold">📌 TO DO LIST</h2>
             <span class="text-xs text-gray-400">優先順位 A-C</span>
        </div>
        <div id="tasks_container" class="space-y-3">
            <%# 優先順位順などでソートしたタスクを表示 %>
            <%= render @tasks %> 
        </div>
        </section>


        <!-- 3. 日常業務進行状況 -->
        <section class="routine-section">
        <div class="routine-header">
            <h2 class="routine-title">🔄 日常業務進行状況</h2>
            
            <%= link_to master_tasks_path, class: "master-link" do %>
            ＋追加・編集
            <% end %>
        </div>

        <div id="routine_tasks" class="routine-grid">
            <%= render partial: 'routine_task', collection: @routine_tasks, as: :task %>
        </div>
        </section>

        <!-- 4. アーカイブ済み -->
        <section class="archive-section">
        
        <div class="archive-header">
            <h2 class="archive-title">📦 完了済み</h2>
            
            <%= form_with url: root_path, method: :get, local: true, class: "date-filter" do |f| %>
            <span class="date-filter-label">表示日:</span>
            <%= f.date_field :date, 
                value: @selected_date, 
                min: 1.months.ago.to_date, 
                max: Date.today, 
                onchange: "this.form.submit();",
                class: "date-input" %>
            <% end %>
        </div>

        <div id="archive-list" class="archive-list">
        <% if @archived_tasks.any? %>
            <% @archived_tasks.each do |task| %>
            <div class="archive-item" id="<%= dom_id(task) %>">
                <div class="archive-item-content">
                <span class="archive-item-title"><%= task.title %></span>
                <span class="archive-item-time"><%= task.updated_at.strftime("%H:%M") %> 完了</span>
                </div>

                <%# 戻すボタンを追加 %>
                <%= link_to "元に戻す", update_status_task_path(id: task.id, status: "todo"), 
                    data: { turbo_method: :patch }, 
                    class: "restore-button" %>
            </div>
            <% end %>
        <% else %>
            <div class="archive-empty">
            <%= @selected_date.strftime("%m/%d") %> の完了タスクはありません
            </div>
        <% end %>
        </div>
    </section>
        <!-- 5. 完了報告生成 -->
        <section class="section-report-gen">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-indigo-300 font-bold">✨ 報告サマリー生成</h2>
                <div class="flex gap-2">
                    <button onclick="generateReport()" class="bg-indigo-600 text-xs px-4 py-1.5 rounded font-bold hover:bg-indigo-500 transition">生成</button>
                    <button onclick="copyToClipboard()" class="bg-gray-700 text-xs px-4 py-1.5 rounded font-bold hover:bg-gray-600 transition">コピー</button>
                </div>
            </div>
            <div id="report-output" class="report-display text-gray-400">
                タスクを完了させてください。
            </div>
        </section>
    </main>

    <div id="toast" class="toast-popup"></div>

</div>